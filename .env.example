# MySQL
MYSQL_ROOT_PASSWORD=pwd
MYSQL_DATABASE=agent_platform

# Backend
DATABASE_URL=mysql+aiomysql://root:pwd@mysql:3306/agent_platform
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=
# Working directory for file operations (defaults to current working directory)
WORKSPACE_ROOT=

